# Copiez ce fichier en .env.local et renseignez vos clés.
# (.env.local n'est JAMAIS commité — voir .gitignore)

# Supabase > Project Settings > API. N'utilisez QUE la clé "anon public".
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique

# Notifications push : clé PUBLIQUE VAPID uniquement (jamais la privée).
# Générez la paire avec :  npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=votre-cle-publique-vapid

# --- Secrets de l'Edge Function (NE PAS mettre ici, voir README §7) ---
# À définir via `supabase secrets set` :
#   VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT
