# Copiez ce fichier en .env.local et renseignez vos clés Supabase.
# (.env.local n'est JAMAIS commité — voir .gitignore)
# Ces deux valeurs se trouvent dans Supabase > Project Settings > API.
# N'utilisez QUE la clé "anon public" ici — jamais la clé service_role.

VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre-cle-anon-publique
